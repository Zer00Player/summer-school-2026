{
  "test_suite": "Отмена бронирования",
  "version": "1.0.0",
  "test_cases": [
    {
      "id": "TC-02.1",
      "title": "Ранняя отмена брони (≥2 часа до старта)",
      "priority": "P0",
      "type": "positive",
      "preconditions": {
        "user_state": "авторизован",
        "booking": {
          "id": 2001,
          "slot_id": 105,
          "status": "active",
          "start_at": "2026-07-06T18:00:00Z",
          "seats_count": 1,
          "rental_count": 0
        },
        "current_time": "2026-07-06T14:00:00Z",
        "hours_until_start": 4
      },
      "steps": [
        {
          "step_number": 1,
          "action": "Перейти в 'Мои записи'",
          "expected": "Отображается список активных броней"
        },
        {
          "step_number": 2,
          "action": "Нажать на активную бронь",
          "expected": "Открывается модальное окно подтверждения отмены"
        },
        {
          "step_number": 3,
          "action": "Прочитать сообщение",
          "expected": "Текст: 'До начала 4 ч. Место освободится.'"
        },
        {
          "step_number": 4,
          "action": "Нажать 'Подтвердить отмену'",
          "expected": "Запрос на отмену отправляется"
        }
      ],
      "expected_result": {
        "booking_status": "cancelled",
        "slot_updated": {
          "booked": "decreased by 1",
          "status": "available"
        },
        "notification_created": {
          "type": "booking_cancelled",
          "text": "Запись отменена"
        },
        "ui_updated": {
          "booking_card_status": "Отменена",
          "slot_button_text": "Записаться"
        }
      }
    },
    {
      "id": "TC-02.2",
      "title": "Поздняя отмена брони (<2 часов до старта)",
      "priority": "P0",
      "type": "positive",
      "preconditions": {
        "booking": {
          "id": 2002,
          "slot_id": 106,
          "status": "active",
          "start_at": "2026-07-06T18:00:00Z",
          "seats_count": 1,
          "rental_count": 1
        },
        "current_time": "2026-07-06T17:00:00Z",
        "hours_until_start": 1
      },
      "steps": [
        {
          "step_number": 1,
          "action": "Нажать на активную бронь",
          "expected": "Открывается модальное окно"
        },
        {
          "step_number": 2,
          "action": "Прочитать сообщение",
          "expected": "Текст: 'До начала менее 2 часов. Место НЕ освободится.'"
        },
        {
          "step_number": 3,
          "action": "Подтвердить отмену",
          "expected": "Бронь отменяется"
        }
      ],
      "expected_result": {
        "booking_status": "late_cancel",
        "slot_updated": {
          "booked": "NOT changed",
          "free_rental_boards": "NOT changed"
        },
        "ui_updated": {
          "booking_card_status": "Поздняя отмена",
          "slot_button_text": "✓ Записан"
        }
      }
    },
    {
      "id": "TC-02.3",
      "title": "Попытка отмены после старта тренировки",
      "priority": "P0",
      "type": "negative",
      "preconditions": {
        "booking": {
          "id": 2003,
          "status": "active",
          "start_at": "2026-07-06T18:00:00Z"
        },
        "current_time": "2026-07-06T18:30:00Z"
      },
      "steps": [
        {
          "step_number": 1,
          "action": "Нажать на бронь, время которой уже прошло",
          "expected": "Открывается модальное окно"
        }
      ],
      "expected_result": {
        "message": "Тренировка уже началась. Отмена недоступна.",
        "cancel_button_disabled": true,
        "booking_status": "active"
      }
    },
    {
      "id": "TC-02.4",
      "title": "Отмена брони на следующий день (BUG-003)",
      "priority": "P0",
      "type": "positive",
      "related_bug": "BUG-003",
      "preconditions": {
        "booking": {
          "id": 2004,
          "slot_id": 205,
          "status": "active",
          "start_at": "2026-07-07T18:00:00Z",
          "date": "Завтра"
        },
        "current_time": "2026-07-06T14:00:00Z",
        "hours_until_start": 28
      },
      "steps": [
        {
          "step_number": 1,
          "action": "Найти бронь на завтра",
          "expected": "Бронь отображается в списке активных"
        },
        {
          "step_number": 2,
          "action": "Нажать на бронь",
          "expected": "Открывается модальное окно отмены"
        },
        {
          "step_number": 3,
          "action": "Подтвердить отмену",
          "expected": "Отмена успешно выполняется"
        }
      ],
      "expected_result": {
        "booking_status": "cancelled",
        "slot_205_updated": {
          "booked": "decreased by 1"
        },
        "notification_created": true
      }
    },
    {
      "id": "TC-02.5",
      "title": "Граница ровно 2 часа",
      "priority": "P1",
      "type": "boundary",
      "preconditions": {
        "booking": {
          "id": 2005,
          "start_at": "2026-07-06T18:00:00Z"
        },
        "current_time": "2026-07-06T16:00:00Z",
        "hours_until_start": 2
      },
      "steps": [
        {
          "step_number": 1,
          "action": "Попытаться отменить бронь ровно за 2 часа",
          "expected": "Отмена выполняется"
        }
      ],
      "expected_result": {
        "booking_status": "cancelled",
        "slot_updated": {
          "booked": "decreased by 1"
        },
        "interpretation": "Ровно 2 часа трактуется как ранняя отмена"
      }
    }
  ]
}
