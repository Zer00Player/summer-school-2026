{
  "test_suite": "Регрессионные тесты для исправленных багов",
  "version": "1.0.0",
  "description": "Тесты проверяют, что исправленные баги не появились снова",
  "test_cases": [
    {
      "id": "TC-05.1",
      "title": "BUG-001: Бонусы не уходят в отрицательные значения",
      "priority": "P0",
      "type": "regression",
      "related_bug": "BUG-001",
      "preconditions": {
        "bonus_balance": 150,
        "slot_price": 1200
      },
      "steps": [
        {
          "step_number": 1,
          "action": "Включить чекбокс 'Оплатить бонусами'",
          "expected": "Разбивка цены: обычная 1 200 ₽, с бонусами 600 ₽"
        },
        {
          "step_number": 2,
          "action": "Подтвердить запись",
          "expected": "Запись создана"
        },
        {
          "step_number": 3,
          "action": "Проверить баланс бонусов",
          "expected": "Баланс положительный"
        }
      ],
      "expected_result": {
        "bonus_balance_after": {
          "calculation": "150 - 50 (использовано) + 3 (начислено) = 103",
          "value": 103,
          "is_positive": true
        },
        "checkbox_disabled_if_zero": true
      },
      "verification": {
        "check": "bonus_balance >= 0",
        "method": "Проверить значение в шапке приложения"
      }
    },
    {
      "id": "TC-05.2",
      "title": "BUG-002: Невозможность двойной записи на один слот",
      "priority": "P0",
      "type": "regression",
      "related_bug": "BUG-002",
      "preconditions": {
        "existing_booking": {
          "slot_id": 105,
          "status": "active"
        }
      },
      "steps": [
        {
          "step_number": 1,
          "action": "Найти слот 105 в расписании",
          "expected": "Кнопка показывает '✓ Записан'"
        },
        {
          "step_number": 2,
          "action": "Попытаться записаться снова",
          "expected": "Кнопка неактивна или показывает сообщение"
        },
        {
          "step_number": 3,
          "action": "Проверить список записей",
          "expected": "Только одна запись на слот 105"
        }
      ],
      "expected_result": {
        "button_text": "✓ Записан",
        "button_clickable": false,
        "bookings_count_for_slot_105": 1,
        "no_duplicate_bookings": true
      },
      "verification": {
        "check": "bookings.filter(b => b.slotId === 105 && b.status === 'active').length === 1",
        "method": "Проверить массив bookings в консоли"
      }
    },
    {
      "id": "TC-05.3",
      "title": "BUG-003: Отмена брони на будущие даты работает",
      "priority": "P0",
      "type": "regression",
      "related_bug": "BUG-003",
      "preconditions": {
        "booking": {
          "id": 2004,
          "slot_id": 205,
          "status": "active",
          "start_at": "2026-07-07T18:00:00Z"
        },
        "current_time": "2026-07-06T14:00:00Z"
      },
      "steps": [
        {
          "step_number": 1,
          "action": "Найти бронь на завтра",
          "expected": "Бронь отображается в активных"
        },
        {
          "step_number": 2,
          "action": "Нажать на бронь",
          "expected": "Открывается модальное окно отмены"
        },
        {
          "step_number": 3,
          "action": "Подтвердить отмену",
          "expected": "Отмена выполняется успешно"
        },
        {
          "step_number": 4,
          "action": "Проверить статус брони",
          "expected": "Статус изменился на 'cancelled'"
        },
        {
          "step_number": 5,
          "action": "Проверить слот 205",
          "expected": "Количество занятых мест уменьшилось"
        }
      ],
      "expected_result": {
        "booking_status": "cancelled",
        "slot_205_booked": "decreased by 1",
        "notification_created": true,
        "cancel_sheet_worked": true
      },
      "verification": {
        "check": "booking.status === 'cancelled' && slot.booked === original_booked - 1",
        "method": "Проверить объекты booking и slot"
      }
    },
    {
      "id": "TC-05.4",
      "title": "Чекбокс бонусов блокируется при нулевом балансе",
      "priority": "P1",
      "type": "regression",
      "related_bug": "BUG-001",
      "preconditions": {
        "bonus_balance": 0
      },
      "steps": [
        {
          "step_number": 1,
          "action": "Открыть экран бронирования",
          "expected": "Чекбокс 'Оплатить бонусами' неактивен"
        },
        {
          "step_number": 2,
          "action": "Попытаться включить чекбокс",
          "expected": "Чекбокс не реагирует"
        }
      ],
      "expected_result": {
        "checkbox_disabled": true,
        "checkbox_checked": false,
        "label_has_class": "disabled"
      },
      "verification": {
        "check": "document.getElementById('useBonus').disabled === true",
        "method": "Проверить в консоли браузера"
      }
    },
    {
      "id": "TC-05.5",
      "title": "Формат отображения мест 'занято/всего'",
      "priority": "P1",
      "type": "regression",
      "preconditions": {
        "slot": {
          "booked": 7,
          "total": 8
        }
      },
      "steps": [
        {
          "step_number": 1,
          "action": "Найти слот с 7/8 местами",
          "expected": "Отображается '7/8'"
        },
        {
          "step_number": 2,
          "action": "Проверить прогресс-бар",
          "expected": "Прогресс-бар заполнен на 87.5%"
        }
      ],
      "expected_result": {
        "display_format": "7/8",
        "progress_bar_width": "87.5%",
        "not_displayed": "1/8"
      },
      "verification": {
        "check": "textContent.includes('7/8') && !textContent.includes('1/8')",
        "method": "Визуальная проверка"
      }
    },
    {
      "id": "TC-05.6",
      "title": "Прозрачность заполненных слотов",
      "priority": "P1",
      "type": "regression",
      "preconditions": {
        "slot": {
          "booked": 8,
          "total": 8,
          "status": "full"
        }
      },
      "steps": [
        {
          "step_number": 1,
          "action": "Найти слот с статусом 'full'",
          "expected": "Карточка полупрозрачная"
        },
        {
          "step_number": 2,
          "action": "Проверить визуальные стили",
          "expected": "Серый бордер, серый фон, opacity 0.5"
        }
      ],
      "expected_result": {
        "card_opacity": 0.5,
        "border_color": "#9e9e9e",
        "background_color": "#f5f5f5",
        "button_text": "Мест нет",
        "button_disabled": true
      },
      "verification": {
        "check": "getComputedStyle(card).opacity === '0.5'",
        "method": "Проверить в DevTools"
      }
    }
  ]
}